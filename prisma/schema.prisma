generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
}
model Company {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  nameAr      String?
  email       String?
  phone       String?
  website     String?
  taxNumber   String?
  commercialNo String?
  address     String?
  city        String?
  country     String?
  logo        String?
  isActive    Boolean      @default(true)

  branches    Branch[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Branch {
  id          String       @id @default(cuid())

  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String       @unique
  name        String
  nameAr      String?

  address     String?
  city        String?
  phone       String?
  email       String?

  isActive    Boolean      @default(true)

  departments Department[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String       @id @default(cuid())

  branchId    String
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  code        String       @unique
  name        String
  nameAr      String?

  description String?

  isActive    Boolean      @default(true)

  positions   Position[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Position {
  id            String      @id @default(cuid())

  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  code          String      @unique
  title         String
  titleAr       String?

  grade         String?
  level         String?

  basicSalary   Decimal?    @db.Decimal(12,2)

  isActive      Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
model Employee {
  id                String           @id @default(cuid())

  employeeNumber    String           @unique

  firstName         String
  middleName        String?
  lastName          String

  fullName          String
  fullNameAr        String?

  gender            Gender

  maritalStatus     MaritalStatus?

  nationality       String?

  nationalId        String?          @unique

  passportNumber    String?          @unique

  email             String?          @unique

  mobile            String?

  dateOfBirth       DateTime?

  hireDate          DateTime

  employmentType    EmploymentType

  status            UserStatus       @default(ACTIVE)

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])

  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id])

  departmentId      String
  department        Department       @relation(fields: [departmentId], references: [id])

  positionId        String
  position          Position         @relation(fields: [positionId], references: [id])

  basicSalary       Decimal?         @db.Decimal(12,2)

  housingAllowance  Decimal?         @db.Decimal(12,2)

  transportAllowance Decimal?        @db.Decimal(12,2)

  foodAllowance     Decimal?         @db.Decimal(12,2)

  communicationAllowance Decimal?    @db.Decimal(12,2)

  bankName          String?

  iban              String?

  emergencyContact  String?

  emergencyPhone    String?

  address           String?

  city              String?

  country           String?

  profileImage      String?

  notes             String?

  createdAt         DateTime         @default(now())

  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([positionId])
}
