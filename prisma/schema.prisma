generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
}
model Company {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  nameAr      String?
  email       String?
  phone       String?
  website     String?
  taxNumber   String?
  commercialNo String?
  address     String?
  city        String?
  country     String?
  logo        String?
  isActive    Boolean      @default(true)

  branches    Branch[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Branch {
  id          String       @id @default(cuid())

  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code        String       @unique
  name        String
  nameAr      String?

  address     String?
  city        String?
  phone       String?
  email       String?

  isActive    Boolean      @default(true)

  departments Department[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String       @id @default(cuid())

  branchId    String
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  code        String       @unique
  name        String
  nameAr      String?

  description String?

  isActive    Boolean      @default(true)

  positions   Position[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Position {
  id            String      @id @default(cuid())

  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  code          String      @unique
  title         String
  titleAr       String?

  grade         String?
  level         String?

  basicSalary   Decimal?    @db.Decimal(12,2)

  isActive      Boolean     @default(true)
  employees     Employee[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
model Employee {

  id                String           @id @default(cuid())

  employeeNumber    String           @unique

  firstName         String
  middleName        String?
  lastName          String

  fullName          String
  fullNameAr        String?

  gender            Gender

  maritalStatus     MaritalStatus?

  nationality       String?

  nationalId        String?          @unique

  passportNumber    String?          @unique

  email             String?          @unique

  mobile            String?

  dateOfBirth       DateTime?

  hireDate          DateTime

  employmentType    EmploymentType

  status            UserStatus       @default(ACTIVE)

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])

  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id])

  departmentId      String
  department        Department       @relation(fields: [departmentId], references: [id])

  positionId        String
  position          Position         @relation(fields: [positionId], references: [id])

  basicSalary       Decimal?         @db.Decimal(12,2)

  housingAllowance  Decimal?         @db.Decimal(12,2)

  transportAllowance Decimal?        @db.Decimal(12,2)

  foodAllowance     Decimal?         @db.Decimal(12,2)

  communicationAllowance Decimal?    @db.Decimal(12,2)

  bankName          String?

  iban              String?

  emergencyContact  String?

  emergencyPhone    String?

  address           String?

  city              String?

  country           String?

  profileImage      String?

  notes             String?

  createdAt         DateTime         @default(now())

  updatedAt         DateTime         @updatedAt

  // ============================
  // Relations
  // ============================

  user              User?

  attendances       Attendance[]

  leaves            Leave[]

  payrolls          Payroll[]

  loans             Loan[]

  custodies         Custody[]

  // ============================

  @@index([companyId])

  @@index([branchId])

  @@index([departmentId])

  @@index([positionId])

}
// ======================================================
// Roles
// ======================================================

model Role {

  id          String   @id @default(cuid())

  code        String   @unique

  name        String

  nameAr      String?

  description String?

  isSystem    Boolean  @default(false)

  isActive    Boolean  @default(true)

  users       User[]

  permissions RolePermission[]

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

}


// ======================================================
// Permissions
// ======================================================

model Permission {

  id          String   @id @default(cuid())

  code        String   @unique

  module      String

  action      String

  name        String

  nameAr      String?

  description String?

  roles       RolePermission[]

}


// ======================================================
// Many-To-Many
// ======================================================

model RolePermission {

  roleId        String

  permissionId  String

  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  assignedAt    DateTime @default(now())

  @@id([roleId, permissionId])

}


// ======================================================
// Users
// ======================================================

model User {

  id              String @id @default(cuid())

  username        String @unique

  email           String @unique

  passwordHash    String

  employeeId      String? @unique

  employee        Employee? @relation("UserEmployee", fields: [employeeId], references: [id])

  roleId          String

  role            Role @relation(fields: [roleId], references: [id])

  status          UserStatus @default(ACTIVE)

  lastLogin       DateTime?

  failedAttempts  Int @default(0)

  lockedUntil     DateTime?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

}
model Attendance {

  id              String @id @default(cuid())

  employeeId      String
  employee        Employee @relation(fields:[employeeId], references:[id], onDelete: Cascade)

  attendanceDate  DateTime

  checkIn         DateTime?

  checkOut        DateTime?

  workingHours    Decimal? @db.Decimal(5,2)

  overtimeHours   Decimal? @db.Decimal(5,2)

  lateMinutes     Int @default(0)

  earlyLeave      Int @default(0)

  notes           String?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  @@index([employeeId])

}


// ======================================================
// Leave Types
// ======================================================

model LeaveType {

  id              String @id @default(cuid())

  code            String @unique

  name            String

  nameAr          String?

  paid            Boolean @default(true)

  maxDays         Int

  requiresApproval Boolean @default(true)

  requests        Leave[]

}


// ======================================================
// Leave Requests
// ======================================================

model Leave {

  id              String @id @default(cuid())

  employeeId      String
  employee        Employee @relation(fields:[employeeId], references:[id], onDelete: Cascade)

  leaveTypeId     String
  leaveType       LeaveType @relation(fields:[leaveTypeId], references:[id])

  startDate       DateTime

  endDate         DateTime

  totalDays       Int

  reason          String?

  status          RequestStatus @default(PENDING)

  approvedBy      String?

  approvedAt      DateTime?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  @@index([employeeId])

}
// ======================================================
// Payroll
// ======================================================

model Payroll {

  id                String @id @default(cuid())

  employeeId        String
  employee          Employee @relation(fields:[employeeId], references:[id], onDelete: Cascade)

  payrollMonth      Int
  payrollYear       Int

  basicSalary       Decimal @db.Decimal(12,2)

  housingAllowance  Decimal @default(0) @db.Decimal(12,2)

  transportAllowance Decimal @default(0) @db.Decimal(12,2)

  foodAllowance     Decimal @default(0) @db.Decimal(12,2)

  communicationAllowance Decimal @default(0) @db.Decimal(12,2)

  overtime          Decimal @default(0) @db.Decimal(12,2)

  bonus             Decimal @default(0) @db.Decimal(12,2)

  deductions        Decimal @default(0) @db.Decimal(12,2)

  loanDeduction     Decimal @default(0) @db.Decimal(12,2)

  tax               Decimal @default(0) @db.Decimal(12,2)

  netSalary         Decimal @db.Decimal(12,2)

  status            PayrollStatus @default(DRAFT)

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

  @@index([employeeId])

  @@unique([employeeId, payrollMonth, payrollYear])

}

// ======================================================
// Employee Loans
// ======================================================

model Loan {

  id                String @id @default(cuid())

  employeeId        String
  employee          Employee @relation(fields:[employeeId], references:[id], onDelete: Cascade)

  loanNumber        String @unique

  amount            Decimal @db.Decimal(12,2)

  installmentAmount Decimal @db.Decimal(12,2)

  totalInstallments Int

  paidInstallments  Int @default(0)

  remainingAmount   Decimal @db.Decimal(12,2)

  requestDate       DateTime

  approvedDate      DateTime?

  status            RequestStatus @default(PENDING)

  notes             String?

  installments      LoanInstallment[]

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Loan Installments
// ======================================================

model LoanInstallment {

  id              String @id @default(cuid())

  loanId          String

  loan            Loan @relation(fields:[loanId], references:[id], onDelete: Cascade)

  installmentNo   Int

  amount          Decimal @db.Decimal(12,2)

  dueDate         DateTime

  paidDate        DateTime?

  paid            Boolean @default(false)

  createdAt       DateTime @default(now())

}
// ======================================================
// Employee Custody (العهد)
// ======================================================

model Custody {

  id              String @id @default(cuid())

  custodyNumber   String @unique

  employeeId      String
  employee        Employee @relation(fields:[employeeId], references:[id], onDelete: Cascade)

  assetType       String

  assetId         String?

  issueDate       DateTime

  expectedReturn  DateTime?

  returnDate      DateTime?

  status          AssetStatus @default(ASSIGNED)

  notes           String?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  @@index([employeeId])

}

// ======================================================
// Office Devices
// ======================================================

model OfficeDevice {

  id                String @id @default(cuid())

  serialNumber      String @unique

  assetCode         String @unique

  name              String

  brand             String?

  model             String?

  category          String?

  purchaseDate      DateTime?

  purchasePrice     Decimal? @db.Decimal(12,2)

  warrantyUntil     DateTime?

  status            AssetStatus @default(AVAILABLE)

  notes             String?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Vehicles
// ======================================================

model Vehicle {

  id                String @id @default(cuid())

  plateNumber       String @unique

  vehicleCode       String @unique

  manufacturer      String

  model             String

  year              Int?

  color             String?

  chassisNumber     String? @unique

  engineNumber      String? @unique

  fuelType          String?

  purchaseDate      DateTime?

  purchasePrice     Decimal? @db.Decimal(12,2)

  currentMileage    Int @default(0)

  insuranceExpiry   DateTime?

  registrationExpiry DateTime?

  status            AssetStatus @default(AVAILABLE)

  notes             String?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}
// ======================================================
// Equipment
// ======================================================

model Equipment {

  id                String @id @default(cuid())

  equipmentCode     String @unique

  serialNumber      String? @unique

  name              String

  category          String?

  manufacturer      String?

  model             String?

  purchaseDate      DateTime?

  purchasePrice     Decimal? @db.Decimal(12,2)

  warrantyUntil     DateTime?

  project           String?

  currentLocation   String?

  status            AssetStatus @default(AVAILABLE)

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

  maintenances      Maintenance[]

}

// ======================================================
// Maintenance
// ======================================================

model Maintenance {

  id                String @id @default(cuid())

  equipmentId       String

  equipment         Equipment @relation(fields:[equipmentId], references:[id], onDelete: Cascade)

  maintenanceNumber String @unique

  maintenanceType   String

  description       String?

  maintenanceDate   DateTime

  nextMaintenance   DateTime?

  cost              Decimal? @db.Decimal(12,2)

  vendor            String?

  technician        String?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Warehouse
// ======================================================

model Warehouse {

  id                String @id @default(cuid())

  code              String @unique

  name              String

  nameAr            String?

  location          String?

  manager           String?

  isActive          Boolean @default(true)

  inventoryItems    Inventory[]

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Inventory
// ======================================================

model Inventory {

  id                String @id @default(cuid())

  warehouseId       String

  warehouse         Warehouse @relation(fields:[warehouseId], references:[id])

  itemCode          String @unique

  itemName          String

  category          String?

  quantity          Decimal @default(0) @db.Decimal(12,2)

  minimumStock      Decimal @default(0) @db.Decimal(12,2)

  unit              String?

  averageCost       Decimal? @db.Decimal(12,2)

  location          String?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Spare Parts
// ======================================================

model SparePart {

  id                String @id @default(cuid())

  partNumber        String @unique

  partName          String

  manufacturer      String?

  category          String?

  quantity          Decimal @default(0) @db.Decimal(12,2)

  unitPrice         Decimal? @db.Decimal(12,2)

  warehouse         String?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

}

// ======================================================
// Fuel Transactions
// ======================================================

model FuelTransaction {

  id                String @id @default(cuid())

  vehicleId         String?

  quantity          Decimal @db.Decimal(12,2)

  totalCost         Decimal @db.Decimal(12,2)

  fuelDate          DateTime

  station           String?

  odometer          Int?

  driver            String?

  notes             String?

  createdAt         DateTime @default(now())

}
